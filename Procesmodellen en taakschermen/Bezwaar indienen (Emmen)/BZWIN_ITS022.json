{
  "name": "BZWIN_ITS022",
  "title": "Vastleggen resultaat bezwaar",
  "display": "form",
  "type": "form",
  "components": [
    {
  "type": "content",
  "key": "HF_Samenvatting",
  "html": "<h5><span style=\"color:hsl( 223, 61%, 42% );\">Vastleggen resultaat bezwaar - samenvatting verloop proces</span></h3>",
  "refreshOnChange": false,
  "input": false,
  "tableView": false
},
    {
      "html": "<p>Het bezwaar valt onder de categorie: <strong>{{CO_Categorie}}</strong><br>Uitkomst ontvankelijkheidstoets: <strong>{{RB_Ontvankelijk}}</strong><br>Aanvullende stukken n.a.v. hersteltermijn zijn aangeleverd en ontvankelijk: <strong>{{RB_Voortgangsbewaking}}</strong></p>",
      "label": "Content",
      "refreshOnChange": false,
      "key": "content",
      "type": "content",
      "input": false,
      "tableView": false
    },
    {},
    {
  "type": "content",
  "key": "HF_OverigeProcesInformatie",
  "html": "<h5><span style=\"color:hsl( 223, 61%, 42% );\">Overige procesinformatie</span></h3>",
  "refreshOnChange": false,
  "input": false,
  "tableView": false
},
{
  "label": "De fatale datum van de zaak is overschreden, geef hier de reden voor het overschrijden van de termijn:",
  "type": "textarea",
  "key": "TA_RedenOverschrijdingTermijn",
  "input": true,
  "validate": {
        "required": true
      },
  "autoExpand": false
},
{
  "label": "Bezwaarmaker heeft afgezien van de mogelijkheid om gehoord te worden:",
  "type": "radio",
  "key": "RB_NietHoren",
  "input": true,
  "validate": {
        "required": true
      },
  "optionsLabelPosition": "right",
  "inline": false,
  "values": [
    {
      "label": "Ja",
      "value": "ja"
    },
    {
      "label": "Nee",
      "value": "nee"
    }
  ]
},
   {
  "label": "Geef de reden waarom bezwaarmaker niet gehoord wilde worden:",
  "type": "textarea",
  "key": "TA_RedenNietGehoord",
  "input": true,
  "validate": {
        "required": true
      },
  "conditional": {
      "show": true,
      "when": "RB_NietHoren",
      "eq": "ja"
    },
  "autoExpand": false
},
   {
      "label": "Bezwaarmaker heeft tijdens of na het opstellen van de BOB alsnog een ingebrekestelling ingediend?: LET OP 2 CONDITIES",
      "optionsLabelPosition": "right",
      "inline": false,
      "tableView": false,
      "values": [
        {
          "label": "Ja",
          "value": "ja",
          "shortcut": ""
        },
        {
          "label": "Nee",
          "value": "nee",
          "shortcut": ""
        }
      ],
      "validateWhenHidden": false,
      "key": "RB_IngebrekeLaterOntvangen",
      "customConditional": "show = (data.RB_Ingebrekestelling == 'nee') || (data.RB_Ingebrekestelling == 'ja' & data.RB.Afhandelingingebrekestelling == 'prematuur');",
      "type": "radio",
      "input": true
    },
   {
  "label": "Datum van ontvangst ingebrekestelling:",
  "type": "datetime",
  "key": "DF_DatumIngebrekeNaBOB",
  "input": true,
  "validate": {
        "required": true
      },
  "conditional": {
      "show": true,
      "when": "RB_IngebrekeLaterOntvangen",
      "eq": "ja"
    },
  "useLocaleSettings": true,
  "format": "dd-MM-yyyy",
  "datePicker": {
    "disableWeekends": false,
    "disableWeekdays": false,
    "minDate": "moment()"
  },
  "enableTime": false,
  "enableMinDateInput": true,
  "enableMaxDateInput": false,
  "widget": {
    "type": "calendar",
    "displayInTimezone": "viewer",
    "locale": "nl",
    "useLocaleSettings": true,
    "allowInput": true,
    "mode": "single",
    "enableTime": false,
    "noCalendar": false,
    "format": "dd-MM-yyyy",
    "minDate": "moment()"
  }
},
   {
  "label": "Bezwaarmaker heeft de gemeente ingebreke gesteld en de toekenning is in het BOB verwerkt, is er een dwangsom verbeurd?:",
  "type": "radio",
  "key": "RB_ToekenningIngebrekestelling",
  "input": true,
  "validate": {
        "required": true
      },
  "optionsLabelPosition": "right",
  "inline": false,
  "values": [
    {
      "label": "Ja",
      "value": "ja"
    },
    {
      "label": "Nee",
      "value": "nee"
    }
  ]
},
   {
  "label": "Geef de hoogte van de verbeurde dwangsom (€):",
  "type": "currency",
  "key": "NF_BedragDwangsom",
  "input": true,
  "validate": {
        "required": true
      },
  "conditional": {
      "show": true,
      "when": "RB_ToekenningIngebrekestelling",
      "eq": "ja"
    },
  "applyMaskOn": "change",
  "mask": false,
  "tableView": false,
  "currency": "EUR",
  "inputFormat": "plain",
  "truncateMultipleSpaces": false,
  "validateWhenHidden": false,
  "delimiter": true,
  "decimalLimit": 2,
  "requireDecimal": true,
  "decimalSymbol": ",",
  "thousandsSeparator": "."
},
