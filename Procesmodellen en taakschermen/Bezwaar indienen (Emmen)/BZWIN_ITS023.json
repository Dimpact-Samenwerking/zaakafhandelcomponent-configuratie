{
  "name": "BZWIN_ITS023",
  "title": "Ontvangen en beoordelen ingebrekestelling",
  "display": "form",
  "type": "form",
  "components": [
    {
  "type": "content",
  "key": "HF_BehandelenIngebrekestelling",
  "html": "<h5><span style=\"color:hsl( 223, 61%, 42% );\">Ontvangen ingebrekestelling</span></h3>",
  "refreshOnChange": false,
  "input": false,
  "tableView": false
},
    {
  "label": "Is er een ingebrekestelling ontvangen?:",
  "type": "radio",
  "key": "RB_Ingebrekestelling",
  "input": true,
  "validate": {
        "required": true
      },
  "optionsLabelPosition": "right",
  "inline": false,
  "values": [
    {
      "label": "Ja",
      "value": "ja"
    },
    {
      "label": "Nee",
      "value": "nee"
    }
  ]
},
    {
  "label": "Datum van ontvangst ingebrekestelling:",
  "type": "datetime",
  "key": "DF_DatumOntvangstIngebrekestelling",
  "input": true,
  "conditional": {
      "show": true,
      "when": "RB_Ingebrekestelling",
      "eq": "ja"
    },
  "useLocaleSettings": true,
  "format": "dd-MM-yyyy",
  "datePicker": {
    "disableWeekends": false,
    "disableWeekdays": false,
    "minDate": "moment()"
  },
  "enableTime": false,
  "enableMinDateInput": true,
  "enableMaxDateInput": false,
  "widget": {
    "type": "calendar",
    "displayInTimezone": "viewer",
    "locale": "nl",
    "useLocaleSettings": true,
    "allowInput": true,
    "mode": "single",
    "enableTime": false,
    "noCalendar": false,
    "format": "dd-MM-yyyy",
    "minDate": "moment()"
  }
},
{
  "type": "content",
  "key": "HF_BeoordelenIngebrekestelling",
  "html": "<h5><span style=\"color:hsl( 223, 61%, 42% );\">Beoordelen ingebrekestelling</span></h3>",
  "refreshOnChange": false,
  "input": false,
  "conditional": {
      "show": true,
      "when": "RB_Ingebrekestelling",
      "eq": "ja"
    },
  "tableView": false
},
{
  "label": "Beoordeling ingebrekestelling:",
  "type": "radio",
  "key": "RB_AfhandelingIngebrekestelling",
  "input": true,
  "validate": {
        "required": true
      },
  "conditional": {
      "show": true,
      "when": "RB_Ingebrekestelling",
      "eq": "ja"
    },
  "optionsLabelPosition": "right",
  "inline": false,
  "values": [
    {
      "label": "De ingebrekestelling is prematuur",
      "value": "prematuur"
    },
    {
      "label": "De ingebrekestelling is tijdig en BOB kan binnen 2 weken worden verzonden",
      "value": "Tijdig binnen 2 weken"
    },
    {
      "label": "De ingebrekestelling is tijdig en BOB kan niet binnen 2 weken worden verzonden",
      "value": "Tijdig na 2 weken"
    }
  ]
},
{
  "type": "content",
  "key": "HF_DocumentenIngebreke",
  "html": "<h5><span style=\"color:hsl( 223, 61%, 42% );\">Opstellen document(en) ingebrekestelling</span></h3>",
  "refreshOnChange": false,
  "input": false,
  "conditional": {
      "show": true,
      "when": "RB_Ingebrekestelling",
      "eq": "ja"
    },
  "tableView": false
},
{
  "type": "smartDocumentsFieldset",
  "key": "TD_ingebrekestelling",
  "input": false,
  "conditional": {
      "show": true,
      "when": "RB_Ingebrekestelling",
      "eq": "ja"
    },
  "components": [
    {
      "label": "Selecteer de juiste brief in de lijst:",
      "type": "select",
      "key": "TD_ingebrekestelling_Template",
      "input": true,
      "widget": "html5",
      "dataSrc": "custom",
      "clearOnRefresh": true,
      "properties": {
    "SmartDocuments_Group": "Dimpact/OpenZaak"
  },
     "attributes": {
    "ZAC_TYPE": "ZAC_smart_documents_template"
  }
    },
    {
      "label": "Maak document",
      "type": "button",
      "key": "TD_ingebrekestelling_Create",
      "input": true,
      "size":"sm",
      "action": "event",
      "showValidations": false,
      "tableView": false,
      "event": "createDocument",
      "properties": {
        "SmartDocuments_Group": "<Dimpact/OpenZaak>",
        "SmartDocuments_<Data_Test>_InformatieobjecttypeUuid": "<3e84c231-7ff8-43c8-a2a0-7e2601f1477a>",
        "SmartDocuments_<OpenZaakTest>_InformatieobjecttypeUuid": "<cf145954-3eeb-4879-9547-e0541029fe01>"
      }
    }
  ]
},
    {
      "label": "",
      "key": "buttons",
      "type": "container",
      "input": false,
      "tableView": false,
      "components": [
        {
          "type": "columns",
          "columns": [
            {
              "width": "auto",
              "components": [
                {
                  "key": "save",
                  "label": "Taak tussentijds opslaan",
                  "type": "button",
                  "size":"sm",
                  "input": true,
                  "action": "saveState",
                  "state": "draft",
                  "tableView": false
                }
              ]
            },
            {
              "width": "auto",
              "components": [
                {
                  "key": "submit",
                  "label": "Taak afronden",
                  "type": "button",
                  "input": true,
                  "size":"sm",
                  "disableOnInvalid": true,
                  "tableView": false
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
