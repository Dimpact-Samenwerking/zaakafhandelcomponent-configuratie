{
  "name": "BPMNe2e_Attributen001",
  "title": "Attributen Testen",
  "display": "form",
  "type": "form",
  "components": [
    {
      "label": "Validatie velden",
      "key": "panel_validatie",
      "type": "panel",
      "input": false,
      "tableView": false,
      "components": [
        {
          "label": "E-mailadres",
          "type": "email",
          "key": "email",
          "input": true,
          "placeholder": "voorbeeld@domein.nl"
        },
        {
          "label": "BSN",
          "type": "textfield",
          "key": "bsn",
          "input": true,
          "validate": {
            "pattern": "^[0-9]{9}$",
            "customMessage": "BSN moet uit precies 9 cijfers bestaan.",
            "maxLength": 9
          },
          "attributes": {
            "maxlength": "9"
          },
          "placeholder": "123456789"
        },
        {
          "label": "Postcode",
          "key": "postcode",
          "type": "textfield",
          "input": true,
          "placeholder": "1234 AB",
          "validate": {
            "pattern": "^[1-9][0-9]{3}\\s?[A-Za-z]{2}$",
            "customMessage": "Postcode moet formaat 1234AB of 1234 AB hebben.",
            "maxLength": 7,
            "minLength": 6
          },
          "attributes": {
            "maxlength": "7"
          }
        }
      ]
    },
    {
      "label": "Extra validatievelden",
      "key": "panel_validatie_extra",
      "type": "panel",
      "input": false,
      "tableView": false,
      "components": [
        {
          "label": "Telefoonnummer",
          "key": "telefoon",
          "type": "textfield",
          "input": true,
          "placeholder": "+31612345678",
          "validate": {
            "pattern": "^[0-9\\+\\-\\s]{10,15}$",
            "maxLength": 15,
            "customMessage": "Telefoonnummer mag 10 t/m 15 tekens bevatten (cijfers, spaties, + of -)."
          },
          "attributes": {
            "maxlength": "15"
          }
        },
        {
          "label": "IBAN",
          "key": "iban",
          "type": "textfield",
          "input": true,
          "placeholder": "NL91ABNA0417164300",
          "validate": {
            "pattern": "^NL[0-9]{2}[A-Z]{4}[0-9]{10}$",
            "maxLength": 18,
            "customMessage": "IBAN moet Nederlands formaat hebben, bijv. NL91ABNA0417164300 (zonder spaties)."
          },
          "attributes": {
            "maxlength": "18"
          }
        },
        {
          "label": "KVK nummer",
          "key": "kvk",
          "type": "textfield",
          "input": true,
          "placeholder": "12345678",
          "validate": {
            "pattern": "^[0-9]{8}$",
            "maxLength": 8,
            "customMessage": "KvK-nummer moet uit 8 cijfers bestaan."
          },
          "attributes": {
            "maxlength": "8"
          }
        },
        {
          "label": "Vestigingsnummer",
          "key": "vestigingsnummer",
          "type": "textfield",
          "input": true,
          "placeholder": "000000000000",
          "validate": {
            "pattern": "^[0-9]{12}$",
            "customMessage": "Vestigingsnummer moet uit 12 cijfers bestaan.",
            "maxLength": 12
          },
          "attributes": {
            "maxlength": "12"
          }
        },
        {
          "label": "Vrije tekst (max 200 tekens)",
          "key": "vrijeTekst",
          "type": "textarea",
          "input": true,
          "rows": 3,
          "validate": {
            "maxLength": 200
          }
        }
      ]
    },
    {
      "label": "Datum en numerieke velden",
      "key": "panel_datum_nummer",
      "type": "panel",
      "input": false,
      "components": [
        {
          "label": "Datum",
          "key": "datum",
          "type": "datetime",
          "input": true,
          "enableTime": false,
          "format": "dd-MM-yyyy"
        },
    {
      "label": "Bedrag",
      "key": "bedragInput",
      "type": "textfield",
      "input": true,
      "prefix": "€",
      "validate": {
        "required": false,
        "pattern": "^\\d{1,3}(\\.\\d{3})*(,\\d{1,2})?$|^\\d+(,\\d{1,2})?$",
        "customMessage": "Voer een bedrag in zoals 12,50 of 1.234,56"
      }
    }
      ]
    },
    {
      "label": "Keuzevelden",
      "key": "panel_keuze",
      "type": "panel",
      "input": false,
      "components": [
        {
          "label": "Communication channel",
          "type": "select",
          "key": "RT_ReferenceTable_Values",
          "input": true,
          "widget": "html5",
          "dataSrc": "custom",
          "attributes": {
            "ZAC_TYPE": "ZAC_referentie_tabel"
          },
          "properties": {
            "ReferenceTable_Code": "COMMUNICATIEKANAAL"
          }
        }
      ]
    },
    {
      "label": "Conditionele velden",
      "key": "panel_conditioneel",
      "type": "panel",
      "input": false,
      "components": [
     {
      "label": "Extra toelichting nodig?",
      "key": "CB_extraToelichting",
      "type": "selectboxes",
      "input": true,
      "optionsLabelPosition": "right",
      "values": [
        {
          "label": "Ja",
          "value": "ja"
        }
      ]
    },
    {
      "label": "Toelichting",
      "key": "TXT_extraToelichting",
      "type": "textarea",
      "input": true,
      "placeholder": "Vul hier een toelichting in",
      "customConditional": "show = data.CB_extraToelichting && data.CB_extraToelichting.ja === true;"
    }
      ]
    },
    {
      "label": "Overige attributen",
      "key": "panel_overig",
      "type": "panel",
      "input": false,
      "tableView": false,
      "components": [
        {
          "label": "Header",
          "key": "header_overig",
          "type": "htmlelement",
          "tag": "h3",
          "content": "Overige componenten (test)"
        },
        {
          "label": "Paragraaf",
          "key": "paragraaf_overig",
          "type": "htmlelement",
          "tag": "p",
          "content": "Dit is een paragraaftekst die je kunt gebruiken om toelichting of instructies te tonen."
        },
        {
          "label": "Separator",
          "key": "separator_overig",
          "type": "htmlelement",
          "tag": "hr",
          "content": ""
        },
        {
          "label": "Label",
          "key": "label_overig",
          "type": "htmlelement",
          "tag": "label",
          "content": "Dit is een label (statische tekst)."
        },
        {
          "label": "Welke optie(s) kies je?",
          "key": "opties",
          "type": "selectboxes",
          "input": true,
          "optionsLabelPosition": "right",
          "values": [
            {
              "label": "Optie A",
              "value": "a"
            },
            {
              "label": "Optie B",
              "value": "b"
            },
            {
              "label": "Anders, namelijk:",
              "value": "anders"
            }
          ]
        },
        {
          "label": "Anders, namelijk",
          "key": "opties_anders",
          "type": "textfield",
          "input": true,
          "placeholder": "Vul hier je andere optie in",
          "customConditional": "show = data.opties && data.opties.anders === true;"
        },
        {
          "label": "Lijst",
          "key": "lijst_test",
          "type": "datagrid",
          "input": true,
          "reorder": true,
          "addAnother": "Item toevoegen",
          "components": [
            {
              "label": "Item",
              "key": "item",
              "type": "textfield",
              "input": true
            }
          ]
        }
      ]
    },
    {
      "label": "Buttons",
      "key": "buttons",
      "type": "container",
      "input": false,
      "tableView": false,
      "components": [
        {
          "type": "columns",
          "columns": [
            {
              "width": "auto",
              "components": [
                {
                  "key": "save",
                  "label": "Opslaan",
                  "type": "button",
                  "theme": "secondary",
                  "input": true,
                  "action": "saveState",
                  "state": "draft",
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            },
            {
              "width": "auto",
              "components": [
                {
                  "key": "submit",
                  "label": "Afronden",
                  "type": "button",
                  "input": true,
                  "disableOnInvalid": true,
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            }
          ],
          "input": false,
          "key": "columns",
          "tableView": false,
          "label": "Columns"
        }
      ]
    }
  ]
}