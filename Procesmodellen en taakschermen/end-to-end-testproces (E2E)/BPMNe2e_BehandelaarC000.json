{
  "name": "BPMNe2e_BehandelaarC000",
  "title": "Toewijzen behandelaar C",
  "display": "form",
  "type": "form",
  "components": [
    {
      "html": "<p><strong>Uitleg regressie testen!</strong></p>",
      "label": "Content",
      "refreshOnChange": false,
      "key": "content",
      "type": "content",
      "input": false,
      "tableView": false
    },
    {
      "legend": "Selecteer de groep en medewerker C",
      "disabled": true,
      "key": "AGM_AdviseurC",
      "conditional": {
        "show": true,
        "when": "RB_toewijzenNaar",
        "eq": "volgendeBehandelaar"
      },
      "type": "fieldset",
      "label": "Field Set",
      "input": false,
      "components": [
        {
          "label": "Groep",
          "widget": "html5",
          "tableView": true,
          "dataSrc": "custom",
          "clearOnRefresh": true,
          "validateWhenHidden": false,
          "key": "AGM_TaakToewijzingAan_GroepC",
          "attributes": {
            "ZAC_TYPE": "ZAC_groep"
          },
          "type": "select",
          "input": true
        },
        {
          "label": "Medewerker",
          "widget": "html5",
          "tableView": true,
          "dataSrc": "custom",
          "refreshOn": "AGM_TaakToewijzingAan_Groep",
          "clearOnRefresh": true,
          "validateWhenHidden": false,
          "key": "AGM_TaakToewijzingAan_MedewerkerC",
          "attributes": {
            "ZAC_TYPE": "ZAC_medewerker"
          },
          "type": "select",
          "input": true
        }
      ],
      "tableView": false
    },
    {
      "label": "Buttons",
      "key": "buttons",
      "type": "container",
      "input": false,
      "tableView": false,
      "components": [
        {
          "type": "columns",
          "columns": [
            {
              "width": "auto",
              "components": [
                {
                  "key": "submit",
                  "label": "Afronden",
                  "type": "button",
                  "input": true,
                  "disableOnInvalid": true,
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            }
          ],
          "input": false,
          "key": "columns",
          "tableView": false,
          "label": "Columns"
        }
      ]
    }
  ]
}