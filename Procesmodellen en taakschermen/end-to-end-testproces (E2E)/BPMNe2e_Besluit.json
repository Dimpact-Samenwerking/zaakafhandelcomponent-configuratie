{
  "name": "BPMNe2e_Besluit001",
  "title": "Besluit vastleggen",
  "display": "form",
  "type": "form",
  "components": [
    {
      "label": "Select besluit",
      "widget": "html5",
      "tableView": true,
      "dataSrc": "custom",
      "validate": {
        "required": true,
        "onlyAvailableItems": true
      },
      "validateWhenHidden": false,
      "key": "ZK_Besluit",
      "attributes": {
        "ZAC_TYPE": "ZAC_besluit"
      },
      "type": "select",
      "input": true
    },
    {
      "label": "Buttons",
      "key": "buttons",
      "type": "container",
      "input": false,
      "tableView": false,
      "components": [
        {
          "type": "columns",
          "columns": [
            {
              "width": "auto",
              "components": [
                {
                  "key": "save",
                  "label": "Opslaan",
                  "type": "button",
                  "theme": "secondary",
                  "input": true,
                  "action": "saveState",
                  "state": "draft",
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            },
            {
              "width": "auto",
              "components": [
                {
                  "key": "submit",
                  "label": "Afronden",
                  "type": "button",
                  "input": true,
                  "disableOnInvalid": true,
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            }
          ],
          "input": false,
          "key": "columns",
          "tableView": false,
          "label": "Columns"
        }
      ]
    }
  ]
}