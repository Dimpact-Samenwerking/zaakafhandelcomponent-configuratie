{
  "name": "BPMNe2e_DocumentTonen001",
  "title": "Documenten tonen",
  "display": "form",
  "type": "form",
  "components": [
    {
      "label": "Documenten",
      "type": "select",
      "key": "ZAAK_Documents_Select",
      "input": true,
      "widget": "choicesjs",
      "multiple": true,
      "clearOnRefresh": true,
      "dataSrc": "custom",
      "placeholder": "Selecteer een of meer documenten",
      "customOptions": {
        "choicesOptions": {
          "removeItemButton": true,
          "placeholder": true,
          "searchEnabled": true,
          "shouldSort": false
        }
      },
      "attributes": {
        "ZAC_TYPE": "ZAC_documenten"
      },
      "tableView": true
    },
    {
      "label": "Buttons",
      "key": "buttons",
      "type": "container",
      "input": false,
      "tableView": false,
      "components": [
        {
          "type": "columns",
          "columns": [
            {
              "width": "auto",
              "components": [
                {
                  "key": "save",
                  "label": "Opslaan",
                  "type": "button",
                  "theme": "secondary",
                  "input": true,
                  "action": "saveState",
                  "state": "draft",
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            },
            {
              "width": "auto",
              "components": [
                {
                  "key": "submit",
                  "label": "Afronden",
                  "type": "button",
                  "input": true,
                  "disableOnInvalid": true,
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            }
          ],
          "input": false,
          "key": "columns",
          "tableView": false,
          "label": "Columns"
        }
      ]
    }
  ]
}