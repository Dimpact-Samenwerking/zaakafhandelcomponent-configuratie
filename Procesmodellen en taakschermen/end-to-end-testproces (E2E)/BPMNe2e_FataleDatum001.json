{
  "name": "BPMNe2e_FataleDatum001",
  "title": "Fatale datum instellen",
  "display": "form",
  "type": "form",
  "components": [
    {
      "label": "Fatale datum van de taakscherm",
      "format": "dd-MM-yyyy",
      "disabled": true,
      "tableView": false,
      "datePicker": {
        "disableWeekends": false,
        "disableWeekdays": false
      },
      "enableTime": false,
      "enableMinDateInput": false,
      "enableMaxDateInput": false,
      "validateWhenHidden": false,
      "key": "DT_fataleDatum",
      "type": "datetime",
      "input": true,
      "widget": {
        "type": "calendar",
        "displayInTimezone": "viewer",
        "locale": "en",
        "useLocaleSettings": false,
        "allowInput": true,
        "mode": "single",
        "enableTime": false,
        "noCalendar": false,
        "format": "dd-MM-yyyy",
        "hourIncrement": 1,
        "minuteIncrement": 1,
        "time_24hr": false,
        "minDate": null,
        "disableWeekends": false,
        "disableWeekdays": false,
        "maxDate": null
      }
    },
    {
      "html": "<p><strong>Check of de gekozen datum daadwerkelijk is ingevuld.</strong></p><figure class=\"image\"><img src=\"data:image/png;base64,\"></figure>",
      "label": "Content",
      "refreshOnChange": false,
      "key": "content",
      "type": "content",
      "input": false,
      "tableView": false
    },
    {
      "label": "Buttons",
      "key": "buttons",
      "type": "container",
      "input": false,
      "tableView": false,
      "components": [
        {
          "type": "columns",
          "columns": [
            {
              "width": "auto",
              "components": [
                {
                  "key": "save",
                  "label": "Opslaan",
                  "type": "button",
                  "theme": "secondary",
                  "input": true,
                  "action": "saveState",
                  "state": "draft",
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            },
            {
              "width": "auto",
              "components": [
                {
                  "key": "submit",
                  "label": "Afronden",
                  "type": "button",
                  "input": true,
                  "disableOnInvalid": true,
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            }
          ],
          "input": false,
          "key": "columns",
          "tableView": false,
          "label": "Columns"
        }
      ]
    }
  ]
}