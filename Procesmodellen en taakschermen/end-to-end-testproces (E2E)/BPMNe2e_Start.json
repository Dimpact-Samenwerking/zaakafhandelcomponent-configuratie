          "validateWhenHidden": false,
          "key": "AGM_TaakToewijzingAan_GroepC",
          "attributes": {
            "ZAC_TYPE": "ZAC_groep"
          },
          "type": "select",
          "input": true
        },
        {
          "label": "Medewerker",
          "widget": "html5",
          "tableView": true,
          "dataSrc": "custom",
          "refreshOn": "AGM_TaakToewijzingAan_GroepC",
          "clearOnRefresh": true,
          "validate": {
