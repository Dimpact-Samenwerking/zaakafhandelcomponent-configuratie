{
  "name": "BPMNe2e_ZaakAfsluiten001",
  "title": "Zaak afsluiten",
  "display": "form",
  "type": "form",
  "components": [
    {
      "html": "<p><strong>De zaak wordt afgesloten met status Afgerond.</strong></p>",
      "key": "content",
      "type": "content",
      "input": false,
      "tableView": false
    },
    {
      "label": "Status",
      "key": "ZK_Status_Display",
      "type": "textfield",
      "input": true,
      "defaultValue": "Afgerond",
      "disabled": true
    },
    {
      "label": "Resultaat",
      "optionsLabelPosition": "right",
      "key": "ZK_Result",
      "widget": "html5",
      "validate": {
        "required": true,
        "onlyAvailableItems": true
      },
      "attributes": {
        "ZAC_TYPE": "ZAC_resultaat"
      },
      "type": "select",
      "input": true,
      "dataSrc": "custom",
      "placeholder": "Kies een resultaat"
    },
    {
      "label": "Buttons",
      "key": "buttons",
      "type": "container",
      "input": false,
      "tableView": false,
      "components": [
        {
          "type": "columns",
          "columns": [
            {
              "width": "auto",
              "components": [
                {
                  "key": "save",
                  "label": "Opslaan",
                  "type": "button",
                  "theme": "secondary",
                  "input": true,
                  "action": "saveState",
                  "state": "draft",
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            },
            {
              "width": "auto",
              "components": [
                {
                  "key": "submit",
                  "label": "Afronden",
                  "type": "button",
                  "input": true,
                  "disableOnInvalid": true,
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            }
          ],
          "input": false,
          "key": "columns",
          "tableView": false,
          "label": "Columns"
        }
      ]
    }
  ]
}