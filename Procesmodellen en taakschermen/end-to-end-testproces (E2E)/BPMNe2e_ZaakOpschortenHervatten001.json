{
  "name": "BPMNe2e_ZaakOpschortenHervatten001",
  "title": "Zaak toewijzen",
  "display": "form",
  "type": "form",
 "components": [
    {
      "label": "Wat wil je doen?",
      "key": "zaakActie",
      "type": "radio",
      "input": true,
      "optionsLabelPosition": "right",
      "values": [
        {
          "label": "Zaak opschorten (eenmalig te testen)",
          "value": "opschorten"
        },
        {
          "label": "Zaak hervatten (eenmalig te testen, zaak dient opgeschort te zijn)",
          "value": "hervatten"
        }
      ],
      "validate": {
        "required": true
      }
    },
    {
      "label": "Aantal dagen opschorten",
      "key": "aantalDagen",
      "type": "number",
      "input": true,
      "decimalLimit": 0,
      "validate": {
        "required": true,
        "min": 1
      },
      "customConditional": "show = data.zaakActie === 'opschorten';",
      "description": "Wordt opgeteld bij de huidige datum."
    },
    {
      "label": "Reden opschorting",
      "key": "opschortingReden",
      "type": "textfield",
      "input": true,
      "validate": {
        "required": true,
        "maxLength": 255
      },
      "attributes": {
        "maxlength": "255"
      },
      "customConditional": "show = data.zaakActie === 'opschorten';"
    },
    {
      "label": "Reden hervatten",
      "key": "hervattenReden",
      "type": "textfield",
      "input": true,
      "validate": {
        "required": true,
        "maxLength": 255
      },
      "attributes": {
        "maxlength": "255"
      },
      "customConditional": "show = data.zaakActie === 'hervatten';"
    },
       {
      "label": "Hervatdatum (optioneel)",
      "key": "hervattenDatumDisplay",
      "type": "datetime",
      "input": true,
      "enableDate": true,
      "enableTime": false,
      "format": "dd-MM-yyyy",
      "useLocaleSettings": true,
      "customConditional": "show = data.zaakActie === 'hervatten';",
      "description": "Als je dit leeg laat, gebruikt ZAC de huidige datum/tijd.",
      "datePicker": {
        "minDate": "moment()"
      }
    },
    {
      "key": "hervattenDatum",
      "type": "hidden",
      "input": true,
      "calculateValue": "value = data.hervattenDatumDisplay ? moment(data.hervattenDatumDisplay).endOf('day').format(\"YYYY-MM-DD[T]HH:mm:ss.SSSZ\") + \"[Europe/Amsterdam]\" : '';"
    },
      {
      "label": "Buttons",
      "key": "buttons",
      "type": "container",
      "input": false,
      "tableView": false,
      "components": [
        {
          "type": "columns",
          "columns": [
            {
              "width": "auto",
              "components": [
                {
                  "key": "save",
                  "label": "Opslaan",
                  "type": "button",
                  "theme": "secondary",
                  "input": true,
                  "action": "saveState",
                  "state": "draft",
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            },
            {
              "width": "auto",
              "components": [
                {
                  "key": "submit",
                  "label": "Afronden",
                  "type": "button",
                  "input": true,
                  "disableOnInvalid": true,
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            }
          ],
          "input": false,
          "key": "columns",
          "tableView": false,
          "label": "Columns"
        }
      ]
    }
  ]
}