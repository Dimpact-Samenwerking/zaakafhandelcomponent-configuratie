{
  "name": "BPMNe2e_ZT001",
  "title": "Zaak toewijzen",
  "display": "form",
  "type": "form",
  "components": [
    {
      "label": "Zaak identificatie",
      "key": "zaakIdentificatie",
      "type": "textfield",
      "disabled": true,
      "attributes": {
        "ZAC_TYPE": "ZAC_process_data"
      },
      "input": true,
      "tableView": true
    },
    {
      "key": "AGM_Adviseur1",
      "type": "fieldset",
      "label": "Field Set",
      "input": false,
      "components": [
        {
          "label": "Groep",
          "widget": "html5",
          "tableView": true,
          "dataSrc": "custom",
          "clearOnRefresh": true,
          "validate": {
            "required": true
          },
          "validateWhenHidden": false,
          "key": "AGM_TaakToewijzingAan_Groep",
          "attributes": {
            "ZAC_TYPE": "ZAC_groep"
          },
          "type": "select",
          "input": true
        },
        {
          "label": "Medewerker",
          "type": "select",
          "key": "AGM_TaakToewijzingAan_Medewerker",
          "widget": "html5",
          "input": true,
          "dataSrc": "custom",
          "refreshOn": "AGM_TaakToewijzingAan_Groep",
          "clearOnRefresh": true,
          "attributes": {
            "ZAC_TYPE": "ZAC_medewerker"
          },
          "tableView": true
        }
      ],
      "tableView": false
    },
    {
      "label": "Reden",
      "key": "assignmentReason",
      "type": "textfield",
      "input": true,
      "tableView": true
    },
    {
      "label": "Buttons",
      "key": "buttons",
      "type": "container",
      "input": false,
      "tableView": false,
      "components": [
        {
          "type": "columns",
          "columns": [
            {
              "width": "auto",
              "components": [
                {
                  "key": "save",
                  "label": "Opslaan",
                  "type": "button",
                  "theme": "secondary",
                  "input": true,
                  "action": "saveState",
                  "state": "draft",
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            },
            {
              "width": "auto",
              "components": [
                {
                  "key": "submit",
                  "label": "Afronden",
                  "type": "button",
                  "input": true,
                  "disableOnInvalid": true,
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            }
          ],
          "input": false,
          "key": "columns",
          "tableView": false,
          "label": "Columns"
        }
      ]
    }
  ]
}