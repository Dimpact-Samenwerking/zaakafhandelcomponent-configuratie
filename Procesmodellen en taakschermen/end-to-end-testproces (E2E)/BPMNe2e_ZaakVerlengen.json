{
  "name": "BPMNe2e_ZV001",
  "title": "Zaak verlengen",
  "display": "form",
  "type": "form",
  "components": [
    {
      "label": "Zaak identificatie",
      "key": "zaakIdentificatie",
      "type": "textfield",
      "input": true,
      "disabled": true,
      "attributes": {
        "ZAC_TYPE": "ZAC_process_data"
      }
    },
    {
      "label": "Zaaktype",
      "key": "zaaktypeOmschrijving",
      "type": "textfield",
      "disabled": true,
      "attributes": {
        "ZAC_TYPE": "ZAC_process_data"
      },
      "input": true
    },
    {
      "label": "Aantal dagen verlengen",
      "key": "extendDays",
      "type": "number",
      "input": true,
      "validate": {
        "required": true,
        "min": 1
      }
    },
    {
      "label": "Verleng reden",
      "key": "extendReason",
      "type": "textfield",
      "input": true,
      "validate": {
        "required": true
      }
    },
    {
      "label": "Buttons",
      "key": "buttons",
      "type": "container",
      "input": false,
      "tableView": false,
      "components": [
        {
          "type": "columns",
          "columns": [
            {
              "width": "auto",
              "components": [
                {
                  "key": "save",
                  "label": "Opslaan",
                  "type": "button",
                  "theme": "secondary",
                  "input": true,
                  "action": "saveState",
                  "state": "draft",
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            },
            {
              "width": "auto",
              "components": [
                {
                  "key": "submit",
                  "label": "Afronden",
                  "type": "button",
                  "input": true,
                  "disableOnInvalid": true,
                  "tableView": false
                }
              ],
              "offset": 0,
              "push": 0,
              "pull": 0,
              "size": "md",
              "currentWidth": "auto"
            }
          ],
          "input": false,
          "key": "columns",
          "tableView": false,
          "label": "Columns"
        }
      ]
    }
  ]
}