    <userTask id="GEN_TN001" name="Accepteren zaak" flowable:assignee="${var:get(zaakBehandelaar)}" flowable:candidateGroups="${var:get(zaakGroep)}" flowable:dueDate="P10D" flowable:formKey="GEN_ITS001" flowable:formFieldValidation="false">
